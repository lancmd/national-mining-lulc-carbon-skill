{
  "schema_version": 2,
  "project_id": "replace_me",
  "workspace": "../outputs/replace_me",
  "inputs": {
    "imagery": ["replace_with_local_multiband_image.tif"],
    "roi": "replace_with_roi.gpkg",
    "mine_boundary": "replace_with_mine_boundary.gpkg",
    "carbon_density": "replace_with_carbon_density.csv",
    "lulc_baseline": null,
    "training_roi": null,
    "model_package": null,
    "dem": null,
    "water_surface_elevation_m": null,
    "subsidence_depth_raster": null,
    "subsidence_w_dat": null,
    "workface_boundary": null,
    "subsidence_water_boundary": null,
    "aquatic_vegetation_boundary": null,
    "bottom_sediment_boundary": null,
    "driver_factors": {
      "dem": null,
      "slope": null,
      "aspect": null,
      "population": null,
      "gdp": null,
      "temperature": null,
      "precipitation": null,
      "road_distance": null,
      "railway_distance": null,
      "river_distance": null,
      "mine_distance": null
    }
  },
  "classification": {
    "enabled": true,
    "engine": "pytorch",
    "scheme": "high_water_coal_7class",
    "output_lulc": "outputs/lulc.tif",
    "output_confidence": "outputs/lulc_confidence.tif",
    "envi_method": "maximum_likelihood"
  },
  "plus": {
    "enabled": false,
    "baseline_year": 2025,
    "target_year": 2030,
    "scenarios": ["ND", "UD", "EP", "RE"],
    "output_workspace": "outputs/plus",
    "resource_extraction": {
      "core_driver": "subsidence_depth",
      "core_driver_input": "inputs.subsidence_depth_raster",
      "core_driver_unit": "m",
      "core_driver_convention": "positive_down",
      "requires_master_grid_alignment": true,
      "additional_driver_factors": ["dem", "slope", "road_distance", "mine_distance"],
      "water_susceptibility": null,
      "w_dat_preprocessing": {
        "source_unit": null,
        "source_convention": null,
        "output_depth_unit": "m",
        "output_depth_convention": "positive_down"
      }
    }
  },
  "invest": {
    "enabled": true,
    "lulc_source": "classification",
    "output_workspace": "outputs/invest"
  },
  "subsidence_water": {
    "enabled": false,
    "mode": "classify_only",
    "workface_boundary": null,
    "water_level_elevation_m": null,
    "output_depth_raster": "outputs/subsidence_water_depth.tif",
    "output_volume_table": "outputs/subsidence_water_volume.csv",
    "output_aquatic_vegetation_raster": "outputs/subsidence_aquatic_vegetation.tif",
    "output_bottom_sediment_raster": "outputs/subsidence_bottom_sediment.tif",
    "output_carbon_table": "outputs/subsidence_water_carbon.csv",
    "thesis_4_3": {
      "water_carbon_density_g_c_m3": null,
      "aquatic_vegetation_carbon_density_t_c_ha": null,
      "bottom_sediment_carbon_density_t_c_ha": null,
      "aquatic_vegetation_depth_threshold_m": null,
      "bottom_sediment_assume_full_waterbed": false,
      "invest_total_carbon_t_c": null,
      "invest_subsidence_water_carbon_t_c": null
    }
  },
  "ecosystem_service": {
    "enabled": false,
    "method": "minmax",
    "criteria_table": "replace_with_ecosystem_criteria.csv",
    "config": "../templates/ecosystem_service_config.json",
    "output_table": "outputs/ecosystem_service_scores.csv"
  },
  "gis_outputs": {
    "enabled": true,
    "aprx": null,
    "layout_name": null,
    "pdf": "outputs/maps/final_layout.pdf",
    "png": "outputs/maps/final_layout.png"
  }
}
