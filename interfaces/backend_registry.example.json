{
  "protocol_version": "1.0",
  "backends": {
    "envi": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/envi_backend.py"],
      "capabilities": ["envi.supervised_classification"]
    },
    "plus": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/plus_backend.py"],
      "capabilities": ["plus.calibrate", "plus.run_scenario"]
    },
    "arcgis": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/local_backend.py", "--backend", "arcgis"],
      "capabilities": ["arcgis.run_operations", "dataset.inspect"]
    },
    "invest": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/local_backend.py", "--backend", "invest"],
      "capabilities": ["invest.run_carbon", "invest.run_model"]
    },
    "pytorch": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/pytorch_backend.py"],
      "capabilities": ["pytorch.validate_model", "pytorch.run_lulc_inference"]
    },
    "project": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/project_backend.py"],
      "capabilities": ["project.build_from_inputs", "project.validate", "project.compile_workflow", "project.run_workflow", "project.prepare_plus_scenarios", "project.submit_workflow", "system.job_status", "system.cancel_job", "system.list_outputs", "analysis.validate_results", "analysis.lulc_accuracy", "analysis.plus_validation", "analysis.invest_consistency"]
    },
    "ecosystem": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/ecosystem_backend.py"],
      "capabilities": ["ecosystem.evaluate", "ecosystem.tradeoff_analysis", "ecosystem.scenario_compare", "ecosystem.water_yield_calibration", "ecosystem.geodetector_factor_analysis", "ecosystem.sensitivity_analysis"]
    }
  }
}
